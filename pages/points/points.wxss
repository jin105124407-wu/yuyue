.points {
  min-height: 100vh;
  background: var(--page-bg);
}

.points-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx;
  margin-bottom: 28rpx;
  color: var(--brand-deep);
  background: linear-gradient(135deg, #dbe9e0, #f6f3e7);
  border-radius: 32rpx;
}

.points-hero text {
  display: block;
  font-size: 26rpx;
}

.points-num {
  margin-bottom: 12rpx;
  font-size: 52rpx !important;
  font-weight: 800;
}

.gift-mark {
  width: 104rpx;
  height: 104rpx;
  display: grid;
  place-items: center;
  border: 2rpx solid rgba(95, 127, 115, 0.28);
  border-radius: 50%;
  color: var(--brand);
  font-size: 42rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.45);
}

.points-badge,
.points-icon {
  position: relative;
  overflow: hidden;
}

.points-badge::before,
.points-icon::before {
  content: "";
  position: absolute;
  inset: 18rpx;
  border: 4rpx solid rgba(95, 127, 115, 0.45);
  border-radius: 50%;
}

.points-badge::after,
.points-icon::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 16rpx;
  width: 42rpx;
  height: 34rpx;
  border-left: 9rpx solid rgba(200, 174, 123, 0.78);
  border-right: 9rpx solid rgba(200, 174, 123, 0.78);
  transform: translateX(-50%);
  clip-path: polygon(0 0, 50% 34%, 100% 0, 100% 100%, 50% 70%, 0 100%);
}

.badge-star,
.points-star {
  position: relative;
  z-index: 2;
  width: 42rpx;
  height: 42rpx;
  background: var(--brand);
  clip-path: polygon(50% 0, 61% 34%, 98% 34%, 68% 55%, 79% 90%, 50% 68%, 21% 90%, 32% 55%, 2% 34%, 39% 34%);
}

.task-list {
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.task-title {
  display: block;
  margin: 0 0 24rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.task {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 80rpx;
  border-top: 1rpx solid rgba(231, 236, 232, 0.9);
  color: var(--text-2);
  font-size: 28rpx;
}

.empty-card {
  min-height: 420rpx;
  display: grid;
  place-items: center;
  padding: 68rpx 44rpx;
  text-align: center;
}

.empty-icon.points-icon {
  width: 132rpx;
  height: 132rpx;
  display: grid;
  place-items: center;
  margin: 0 auto 34rpx;
  border: 2rpx solid rgba(95, 127, 115, 0.22);
  border-radius: 50%;
  background:
    radial-gradient(circle at 34% 26%, rgba(255, 255, 255, 0.95), transparent 26%),
    linear-gradient(135deg, rgba(242, 247, 241, 0.95), rgba(248, 240, 217, 0.82));
  box-shadow: 0 18rpx 38rpx rgba(63, 98, 88, 0.08);
}

.points-icon::before {
  inset: 24rpx;
  border-width: 5rpx;
}

.points-icon::after {
  bottom: 20rpx;
}

.points-icon .points-star {
  width: 54rpx;
  height: 54rpx;
}

.empty-title {
  display: block;
  margin: 0 0 20rpx;
  color: var(--text);
  font-size: 40rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin: 0 0 40rpx;
  color: var(--muted);
  font-size: 28rpx;
  line-height: 1.65;
}

.empty-card .btn {
  width: 220rpx;
  margin: 0 auto;
}
