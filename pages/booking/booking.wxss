.booking {
  min-height: 100vh;
  background: var(--page-bg);
}

.content.no-tab {
  padding-bottom: calc(34rpx + env(safe-area-inset-bottom));
}

.staff-hero {
  height: 380rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin: 0 -24rpx 24rpx;
  background:
    linear-gradient(rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.78)),
    url("https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&w=900&q=80");
  background-position: center;
  background-size: cover;
  position: relative;
  overflow: hidden;
}

.staff-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 28%, rgba(255, 248, 229, 0.22), transparent 30%),
    linear-gradient(112deg, transparent 0 58%, rgba(255, 255, 255, 0.28) 59%, transparent 68%);
  pointer-events: none;
}

.staff-head {
  position: relative;
  z-index: 1;
  font-size: 32rpx;
  font-weight: 600;
  margin: 0;
}

.staff-avatar {
  z-index: 1;
  width: 164rpx;
  height: 164rpx;
  border: 6rpx solid var(--gold);
  border-radius: 50%;
  background: rgba(95, 127, 115, 0.08);
  box-shadow: 0 20rpx 44rpx rgba(63, 98, 88, 0.18);
  overflow: hidden;
  position: relative;
}

.staff-avatar-img {
  width: 100%;
  height: 100%;
  object-position: center 18%;
}

.staff-avatar::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(95, 127, 115, 0.08);
}

.staff-name {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  color: var(--brand-deep);
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
}

.staff-name text {
  display: block;
  color: var(--muted);
  font-size: 26rpx;
  font-weight: 500;
}

.booking-title {
  display: block;
  color: var(--text-2);
  font-size: 34rpx;
  margin: 32rpx 0 20rpx;
  font-weight: 600;
}

.date-strip {
  white-space: nowrap;
  margin: 0 -24rpx;
  padding: 0;
  border-top: 1rpx solid var(--line);
  border-bottom: 1rpx solid var(--line);
  background: #fff;
  width: 750rpx;
  box-sizing: border-box;
}

.date-strip-inner {
  display: flex;
  width: 3240rpx;
  background: #fff;
}

.date-btn {
  width: 108rpx;
  min-width: 108rpx;
  flex: 0 0 108rpx;
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: var(--text-2);
  background: #fff;
  font-size: 22rpx;
  border-right: 1rpx solid rgba(231, 236, 232, 0.72);
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  vertical-align: top;
}

.date-btn text:first-child {
  font-size: 23rpx;
  font-weight: 700;
}

.date-btn text:last-child {
  font-size: 20rpx;
}

.date-btn.active {
  color: #fff;
  background: var(--gold);
  font-weight: 700;
}

.time-grid-wrap {
  margin: 0 -24rpx 28rpx;
  background: #fff;
  border-bottom: 1rpx solid var(--line);
}

.time-row {
  display: grid;
  grid-template-columns: 92rpx repeat(6, minmax(72rpx, 1fr));
  min-height: 100rpx;
  border-bottom: 1rpx solid var(--line);
}

.time-row:last-child {
  border-bottom: 0;
}

.time-icon {
  display: grid;
  place-items: center;
  color: #8a918d;
  border-right: 1rpx solid var(--line);
  font-size: 34rpx;
}

.time-cell {
  min-width: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #56615d;
  background: #fff;
  font-size: 25rpx;
  border-right: 1rpx solid rgba(231, 236, 232, 0.72);
  margin: 0;
  padding: 0;
  line-height: 1;
}

.time-cell text {
  display: block;
  color: inherit;
  font-size: inherit;
  line-height: 1;
}

.time-cell:last-child {
  border-right: 0;
}

.time-cell.disabled {
  color: var(--disabled);
  background: #fbfcfb;
}

.time-cell.active {
  color: #fff;
  background: var(--gold);
  font-weight: 700;
}

.row-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 32rpx 0 20rpx;
}

.row-head > text {
  font-size: 34rpx;
  font-weight: 600;
}

.row-head .row-hint {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 500;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.service-card {
  width: 100%;
  min-height: 224rpx;
  padding: 26rpx 24rpx;
  border: 3rpx solid var(--line);
  border-radius: 28rpx;
  background: #fff;
  text-align: left;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  box-sizing: border-box;
  white-space: normal;
  line-height: 1.35;
}

.service-card h4,
.service-card p {
  margin: 0;
}

.service-card.active {
  border-color: var(--brand);
  box-shadow: 0 16rpx 40rpx rgba(63, 98, 88, 0.12);
}

.check {
  width: 42rpx;
  height: 42rpx;
  display: grid;
  place-items: center;
  border: 2rpx solid var(--line);
  border-radius: 50%;
  color: #fff;
  margin-bottom: 14rpx;
  font-size: 22rpx;
}

.service-card.active .check {
  border-color: var(--brand);
  background: var(--brand);
}

.service-name {
  display: block;
  margin: 0 0 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  color: var(--text);
}

.service-desc {
  display: block;
  flex: 1;
  margin: 0 0 16rpx;
  color: var(--text-2);
  font-size: 22rpx;
  line-height: 1.5;
}

.duration {
  color: var(--brand-deep);
  font-size: 24rpx;
  font-weight: 700;
}

.notice {
  display: flex;
  gap: 16rpx;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  color: #8e7344;
  background: var(--gold-soft);
  font-size: 24rpx;
}

.field {
  margin-top: 28rpx;
}

.field > text {
  display: block;
  margin: 0 0 16rpx;
  font-size: 30rpx;
  color: var(--text-2);
  font-weight: 500;
}

textarea {
  width: 100%;
  min-height: 168rpx;
  padding: 24rpx;
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  background: #fff;
  color: var(--text);
  font-size: 28rpx;
}

.fixed-action {
  margin: 36rpx 0 0;
  padding-bottom: 4rpx;
}

.success-content {
  padding-left: 0;
  padding-right: 0;
}

.success-block {
  padding: 68rpx 36rpx 44rpx;
  text-align: center;
  background: #fff;
  border-bottom: 1rpx solid var(--line);
}

.success-icon {
  width: 148rpx;
  height: 148rpx;
  display: grid;
  place-items: center;
  margin: 0 auto 28rpx;
  border: 8rpx solid currentColor;
  border-radius: 50%;
  color: var(--brand);
  font-size: 70rpx;
  font-weight: 700;
}

.success-title {
  display: block;
  margin: 0 0 24rpx;
  color: var(--text-2);
  font-size: 36rpx;
  line-height: 1.55;
  font-weight: 500;
  white-space: pre-line;
}

.success-tip {
  display: block;
  color: var(--gold);
  font-size: 30rpx;
  line-height: 1.65;
}

.success-actions {
  padding: 36rpx;
}

.success-actions .btn {
  flex: 1;
}

.list-row .strong {
  color: var(--text);
  font-size: 28rpx;
  text-align: right;
  font-weight: 700;
}
