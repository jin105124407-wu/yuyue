.mall {
  min-height: 100vh;
  background: var(--page-bg);
}

.search {
  height: 84rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  color: var(--muted);
  background: #fff;
  border: 1rpx solid rgba(231, 236, 232, 0.9);
}

.empty-card {
  min-height: 600rpx;
  display: grid;
  place-items: center;
  margin-top: 44rpx;
  padding: 68rpx 44rpx;
  text-align: center;
}

.empty-icon.shop-icon {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  margin: 0 auto 34rpx;
  border: 2rpx solid rgba(95, 127, 115, 0.22);
  border-radius: 42rpx;
  background:
    radial-gradient(circle at 34% 26%, rgba(255, 255, 255, 0.95), transparent 26%),
    linear-gradient(135deg, rgba(242, 247, 241, 0.95), rgba(248, 240, 217, 0.82));
  box-shadow: 0 18rpx 38rpx rgba(63, 98, 88, 0.08);
}

.shop-icon::before {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 26rpx;
  height: 58rpx;
  border: 5rpx solid var(--brand);
  border-radius: 8rpx 8rpx 18rpx 18rpx;
  background: rgba(255, 255, 255, 0.32);
}

.shop-handle {
  position: absolute;
  left: 47rpx;
  top: 37rpx;
  width: 38rpx;
  height: 28rpx;
  border: 5rpx solid var(--brand);
  border-bottom: 0;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 2;
}

.shop-line {
  position: absolute;
  left: 49rpx;
  bottom: 48rpx;
  width: 34rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: rgba(95, 127, 115, 0.42);
  z-index: 2;
}

.empty-title {
  display: block;
  margin: 0 0 20rpx;
  color: var(--text);
  font-size: 40rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin: 0 0 40rpx;
  color: var(--muted);
  font-size: 28rpx;
  line-height: 1.65;
}

.empty-card .btn {
  width: 220rpx;
  margin: 0 auto;
}
