.home {
  min-height: 100vh;
}

.navbar {
  height: 112rpx;
  display: grid;
  grid-template-columns: 1fr;
  align-items: center;
  padding: 0 24rpx 0 36rpx;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid rgba(231, 236, 232, 0.76);
}

.brand-logo {
  display: flex;
  flex-direction: column;
  line-height: 1;
}

.wordmark {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 36rpx;
  color: var(--brand-deep);
  letter-spacing: 1.5rpx;
}

.tagline {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 19rpx;
  letter-spacing: 3rpx;
}

.photo {
  background-size: cover;
  background-position: center;
  position: relative;
  overflow: hidden;
}

.photo::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(63, 98, 88, 0.4), rgba(255, 255, 255, 0.03));
  pointer-events: none;
}

.hero {
  height: 332rpx;
  border-radius: 32rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(235, 220, 184, 0.76);
  background-image:
    linear-gradient(90deg, rgba(35, 58, 49, 0.7), rgba(91, 103, 82, 0.28) 58%, rgba(255, 248, 229, 0.08)),
    linear-gradient(180deg, rgba(255, 248, 229, 0.08), rgba(31, 55, 47, 0.14)),
    url("https://plus.unsplash.com/premium_photo-1683147632503-0b6134eec32b?auto=format&fit=crop&fm=jpg&q=86&w=900");
  background-size: cover;
  background-position: center 42%;
  box-shadow: 0 28rpx 56rpx rgba(63, 98, 88, 0.11);
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 78% 38%, transparent 0 48rpx, rgba(255, 248, 229, 0.2) 50rpx 54rpx, transparent 56rpx),
    radial-gradient(circle at 88% 46%, transparent 0 64rpx, rgba(200, 174, 123, 0.18) 66rpx 70rpx, transparent 72rpx),
    linear-gradient(132deg, transparent 0 58%, rgba(255, 255, 255, 0.22) 59%, transparent 68%);
  opacity: 0.72;
  pointer-events: none;
}

.hero::after {
  background:
    linear-gradient(90deg, rgba(35, 58, 49, 0.62), rgba(79, 93, 70, 0.28) 52%, rgba(255, 248, 229, 0.08)),
    radial-gradient(circle at 82% 24%, rgba(244, 232, 200, 0.28), transparent 32%);
  pointer-events: none;
}

.hero-copy {
  position: absolute;
  z-index: 1;
  left: 44rpx;
  top: 52rpx;
  color: #fff;
  text-shadow: 0 4rpx 28rpx rgba(31, 39, 36, 0.18);
}

.hero-title {
  display: block;
  margin: 0;
  font-size: 62rpx;
  line-height: 1.22;
  font-weight: 500;
  color: #fff3d8;
  text-shadow: 0 4rpx 20rpx rgba(25, 48, 40, 0.28);
}

.hero-brand {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

.pager {
  position: absolute;
  z-index: 2;
  left: 50%;
  bottom: 24rpx;
  display: flex;
  gap: 14rpx;
  transform: translateX(-50%);
}

.pager text {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.58);
}

.pager .active {
  width: 14rpx;
  border-radius: 50%;
  background: var(--brand);
}

.slogan {
  margin: -2rpx 0 28rpx;
  color: var(--brand-deep);
  font-family: Georgia, "Times New Roman", serif;
  font-size: 25rpx;
  letter-spacing: 3rpx;
  text-align: center;
}

.login-card {
  display: grid;
  grid-template-columns: 132rpx 1fr;
  align-items: center;
  gap: 24rpx;
  min-height: 156rpx;
  padding: 16rpx 12rpx 20rpx 4rpx;
  margin: 8rpx 0 32rpx;
  border: 0;
  background:
    linear-gradient(90deg, rgba(245, 250, 246, 0.95), rgba(255, 255, 255, 0.92)),
    radial-gradient(circle at 8% 22%, rgba(244, 232, 200, 0.2), transparent 24%);
}

.login-avatar-stack {
  width: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-card .avatar {
  width: 104rpx;
  height: 104rpx;
  flex-basis: 104rpx;
  display: block;
  border: 4rpx solid rgba(244, 232, 200, 0.96);
  background: #fffaf1 url("/assets/images/login-avatar-eastern.png") center 42% / cover no-repeat;
  box-shadow: 0 10rpx 24rpx rgba(63, 98, 88, 0.08);
}

.login-card .tag {
  height: 32rpx;
  padding: 0 14rpx;
  margin-top: -16rpx;
  font-size: 16rpx;
  line-height: 32rpx;
  z-index: 2;
}

.user-meta {
  display: grid;
  align-content: center;
  gap: 12rpx;
  padding-top: 6rpx;
  min-width: 0;
}

.login-card .user-row {
  margin: 0;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(95, 127, 115, 0.32);
}

.login-card .muted {
  color: #8a9691;
  font-size: 22rpx;
  line-height: 1.3;
}

.quick {
  display: grid;
  justify-items: stretch;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.quick-main,
.quick-sub {
  width: 100%;
  min-width: 100%;
  max-width: none;
  display: block;
  justify-self: stretch;
  margin: 0;
  border-radius: 0;
  color: #fff;
  background-color: var(--brand-deep);
  position: relative;
  overflow: hidden;
  text-align: left;
}

.quick-main {
  height: 172rpx;
  padding: 36rpx;
  background-image:
    linear-gradient(90deg, rgba(31, 61, 52, 0.96), rgba(63, 98, 88, 0.68) 58%, rgba(200, 174, 123, 0.18)),
    url("https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=900&q=86");
  background-size: cover;
  background-position: center 44%;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.quick-sub {
  min-height: 140rpx;
  padding: 32rpx;
  background-image:
    linear-gradient(90deg, rgba(38, 70, 60, 0.92), rgba(63, 98, 88, 0.64)),
    url("https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?auto=format&fit=crop&w=700&q=84");
  background-size: cover;
  background-position: center 42%;
}

.quick-sub.refer {
  background-image:
    linear-gradient(90deg, rgba(38, 70, 60, 0.92), rgba(63, 98, 88, 0.62), rgba(200, 174, 123, 0.18)),
    url("https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&w=700&q=84");
  background-position: center 48%;
}

.quick-sub.reward {
  background-image:
    linear-gradient(90deg, rgba(38, 70, 60, 0.92), rgba(63, 98, 88, 0.62), rgba(244, 232, 200, 0.14)),
    url("https://images.unsplash.com/photo-1598440947619-2c35fc9aa908?auto=format&fit=crop&w=700&q=84");
  background-position: center 45%;
}

.quick-main::before,
.quick-sub::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 12% 18%, rgba(244, 232, 200, 0.18), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 45%);
  pointer-events: none;
}

.quick-main::after,
.quick-sub::after {
  content: "";
  position: absolute;
  right: -60rpx;
  top: -48rpx;
  width: 252rpx;
  height: 192rpx;
  border: 1rpx solid rgba(255, 248, 229, 0.28);
  border-radius: 62% 38% 55% 45%;
  transform: rotate(-15deg);
  background:
    radial-gradient(circle at 36% 48%, transparent 0 36rpx, rgba(255, 248, 229, 0.18) 38rpx 42rpx, transparent 44rpx),
    radial-gradient(circle at 58% 42%, transparent 0 44rpx, rgba(255, 248, 229, 0.14) 46rpx 50rpx, transparent 52rpx);
  opacity: 0.78;
  pointer-events: none;
}

.quick-sub::after {
  right: -68rpx;
  top: -32rpx;
  width: 192rpx;
  height: 152rpx;
}

.quick-logo {
  position: relative;
  z-index: 2;
  font-family: Georgia, "Times New Roman", serif;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 36rpx;
}

.quick-title {
  position: absolute;
  z-index: 2;
  right: 36rpx;
  bottom: 68rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.16;
  text-align: right;
  white-space: nowrap;
  text-shadow: 0 4rpx 16rpx rgba(22, 42, 35, 0.38);
}

.quick-sub .quick-title {
  right: 24rpx;
  bottom: 64rpx;
  max-width: calc(100% - 48rpx);
}

.click {
  position: absolute;
  z-index: 2;
  right: 24rpx;
  bottom: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 30rpx;
  letter-spacing: 1.2rpx;
  white-space: nowrap;
  text-shadow: 0 4rpx 16rpx rgba(22, 42, 35, 0.38);
}

.store-card {
  padding: 24rpx;
}

.store-photo {
  height: 300rpx;
  border-radius: 24rpx;
  background: #dce7e1;
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 248, 229, 0.3),
    0 20rpx 44rpx rgba(63, 98, 88, 0.08);
}

.store-photo-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.store-photo::after {
  z-index: 2;
  background:
    linear-gradient(90deg, rgba(31, 55, 47, 0.42), rgba(95, 127, 115, 0.12) 52%, rgba(255, 248, 229, 0.08)),
    linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(31, 55, 47, 0.22));
}

.store-title {
  display: block;
  margin: 24rpx 0 12rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.info-line {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  color: var(--text-2);
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.store-card .btn-row .btn {
  flex: 1;
  height: 76rpx;
  border-radius: 22rpx;
  padding: 0 10rpx;
  font-size: 23rpx;
}

.store-card .map-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.map-icon {
  position: relative;
  width: 22rpx;
  height: 28rpx;
  flex: 0 0 22rpx;
}

.map-icon::before {
  content: "";
  position: absolute;
  left: 3rpx;
  top: 0;
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid currentColor;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
}

.map-icon::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 6rpx;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: currentColor;
}

.story {
  height: 720rpx;
  border-radius: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 56rpx 36rpx;
  text-align: center;
  color: #fff;
  background-image:
    linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(63, 98, 88, 0.58)),
    url("https://images.unsplash.com/photo-1522337660859-02fbefca4702?auto=format&fit=crop&w=900&q=80");
  background-size: cover;
  background-position: center;
}

.story::before {
  content: "";
  position: absolute;
  inset: 48rpx 36rpx 144rpx;
  border: 1rpx solid rgba(255, 248, 229, 0.24);
  border-radius: 56% 44% 60% 40%;
  background:
    radial-gradient(ellipse at 45% 36%, transparent 0 140rpx, rgba(255, 248, 229, 0.18) 144rpx 148rpx, transparent 152rpx),
    radial-gradient(ellipse at 58% 40%, transparent 0 172rpx, rgba(255, 248, 229, 0.12) 176rpx 180rpx, transparent 184rpx);
}

.story > view {
  position: relative;
  z-index: 2;
}

.story-title {
  display: block;
  margin: 0 0 24rpx;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 56rpx;
  letter-spacing: 4rpx;
  font-weight: 400;
}

.story-text {
  display: block;
  color: rgba(255, 255, 255, 0.9);
  font-size: 30rpx;
  letter-spacing: 2rpx;
}
