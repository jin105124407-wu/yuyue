<view class="booking-history">
  <view class="content no-tab">
    <view class="orders-tabs">
      <button class="orders-tab {{activeTab === 'booked' ? 'active' : ''}}" data-tab="booked" bindtap="switchTab">预约</button>
      <button class="orders-tab {{activeTab === 'canceled' ? 'active' : ''}}" data-tab="canceled" bindtap="switchTab">已取消</button>
    </view>

    <block wx:if="{{filteredList.length > 0}}">
      <view wx:for="{{filteredList}}" wx:key="_id" class="booking-card {{item.status === 'canceled' ? 'canceled-card' : ''}}">
        <view class="booking-thumb">
          <image class="booking-thumb-img" src="{{item.staffAvatar || '/assets/images/staff-fenfen.jpg'}}" mode="aspectFill"></image>
        </view>
        <view class="booking-meta">
          <text class="order-no">{{item.displayOrderNo || item.orderNo || item._id}}</text>
          <text>预约时间：{{item.date}} {{item.startTime}}</text>
          <text>预约项目：{{item.serviceName}}</text>
          <text>预约美容师：{{item.staffName || '芬芬'}}</text>
        </view>
        <text class="status">
          {{item.status === 'canceled' ? '已取消' : item.status === 'confirmed' ? '待受理' : item.status === 'done' ? '已完成' : '待受理'}}
        </text>
        <view wx:if="{{item.status !== 'canceled'}}" class="booking-actions">
          <button class="text-btn" bindtap="showDetailTip">查看详情</button>
          <button class="text-btn" data-id="{{item._id}}" bindtap="cancelBooking">取消预约</button>
        </view>
      </view>
    </block>

    <view wx:else class="empty-card card">
      <view>
        <view class="empty-icon">日</view>
        <text class="empty-title">暂无预约记录</text>
        <text class="empty-desc">去预约一次护理吧</text>
        <button class="btn" bindtap="goBooking">去预约</button>
      </view>
    </view>
  </view>
</view>
