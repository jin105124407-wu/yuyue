.logout {
  margin-top: 20rpx;
}

.service-modal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.modal-phone {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--brand);
  margin-bottom: 32rpx;
  letter-spacing: 4rpx;
}

.modal-divider {
  height: 1rpx;
  background: var(--line);
  margin-bottom: 32rpx;
}

.modal-call-btn {
  background: var(--brand);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 48rpx;
  margin-bottom: 20rpx;
}

.modal-cancel {
  font-size: 30rpx;
  color: var(--muted);
  padding: 20rpx 0;
}
