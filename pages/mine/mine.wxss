.mine {
  min-height: 100vh;
  background: var(--page-bg);
}

.my-hero {
  margin: -24rpx -24rpx 0;
  min-height: 368rpx;
  padding: 48rpx 32rpx 36rpx;
  background:
    radial-gradient(circle at 24% 18%, rgba(244, 232, 200, 0.2), transparent 22%),
    radial-gradient(circle at 82% 12%, rgba(204, 224, 210, 0.28), transparent 22%),
    repeating-linear-gradient(112deg, rgba(255, 255, 255, 0.06) 0 2rpx, transparent 4rpx 48rpx),
    linear-gradient(135deg, #13281f 0%, #27493e 54%, #dce9df 100%);
}

.member-card {
  position: relative;
  min-height: 282rpx;
  padding: 36rpx 40rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.46);
  border-radius: 48rpx;
  color: #38554c;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(217, 238, 205, 0.96), rgba(249, 244, 216, 0.92)),
    radial-gradient(circle at 82% 16%, rgba(255, 255, 255, 0.72), transparent 24%);
  box-shadow: 0 20rpx 42rpx rgba(31, 52, 44, 0.16);
}

.member-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(110deg, rgba(255, 255, 255, 0.28), transparent 28%),
    radial-gradient(circle at 72% 26%, rgba(255, 255, 255, 0.34), transparent 20%),
    repeating-linear-gradient(135deg, rgba(63, 98, 88, 0.06) 0 1rpx, transparent 1rpx 22rpx);
  pointer-events: none;
}

.member-main {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 120rpx minmax(0, 1fr);
  gap: 22rpx;
  align-items: start;
  padding-right: 58rpx;
}

.member-card .avatar {
  width: 120rpx;
  height: 120rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.84);
  box-shadow: 0 16rpx 36rpx rgba(63, 98, 88, 0.16);
}

.member-avatar {
  display: block;
  background: #fffaf1;
  overflow: hidden;
}

.member-copy {
  min-width: 0;
}

.member-copy .user-row {
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.member-card .tag {
  flex: 0 0 auto;
  height: 40rpx;
  padding: 0 18rpx;
  background: linear-gradient(90deg, #f5dfad, #f8edc8);
  font-size: 20rpx;
  line-height: 40rpx;
  white-space: nowrap;
}

.member-divider {
  position: relative;
  z-index: 1;
  width: 45%;
  height: 4rpx;
  margin: 24rpx 0 20rpx;
  background: rgba(95, 127, 115, 0.32);
}

.member-upgrade {
  position: relative;
  z-index: 1;
  display: block;
  color: #3d5c52;
  font-size: 26rpx;
  line-height: 1.55;
  font-weight: 500;
  max-width: 86%;
}

.member-emblem {
  position: absolute;
  z-index: 1;
  right: 36rpx;
  top: 40rpx;
  width: 112rpx;
  height: 112rpx;
  opacity: 0.48;
}

.member-emblem::before,
.member-emblem::after {
  content: "";
  position: absolute;
  inset: 20rpx;
  border: 16rpx solid rgba(63, 98, 88, 0.45);
  border-radius: 48% 52% 48% 52%;
  transform: rotate(45deg);
  background: rgba(255, 255, 255, 0.08);
}

.member-emblem::after {
  inset: 44rpx;
  border-width: 12rpx;
  transform: rotate(-45deg);
  border-color: rgba(255, 255, 255, 0.72);
}

.member-card .user-name {
  color: #3d5c52;
  flex: 0 1 auto;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 32rpx;
  line-height: 1.25;
  white-space: normal;
}

.member-card .muted {
  display: block;
  color: rgba(61, 92, 82, 0.74);
  font-size: 26rpx;
  line-height: 1.35;
  white-space: normal;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 0 -24rpx 24rpx;
  padding: 36rpx 0;
  background: #fff;
}

.stat {
  text-align: center;
}

.stat .num {
  display: block;
  margin-bottom: 16rpx;
  font-size: 44rpx;
  color: var(--text);
  font-weight: 700;
}

.stat text:last-child {
  color: var(--muted);
  font-size: 26rpx;
}

.feature-card {
  padding: 36rpx 28rpx 40rpx;
  margin-bottom: 24rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(252, 249, 240, 0.96));
}

.feature-title {
  display: block;
  margin: 0 0 32rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.feature-grid {
  display: grid;
  gap: 40rpx 20rpx;
}

.service-grid {
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx 16rpx;
}

.other-grid {
  grid-template-columns: repeat(3, 1fr);
  gap: 44rpx 28rpx;
}

.feature {
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 0;
  border: 0;
  box-sizing: border-box;
  display: grid;
  gap: 18rpx;
  justify-items: center;
  color: var(--text-2);
  background: transparent;
  font-size: 26rpx;
  line-height: 1.2;
}

.feature::after {
  border: 0;
}

.feature .circle {
  width: 116rpx;
  height: 116rpx;
  display: grid;
  place-items: center;
  border: 3rpx solid rgba(95, 127, 115, 0.48);
  border-radius: 50%;
  color: #7fa197;
  background:
    radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.9), transparent 32%),
    rgba(242, 247, 241, 0.68);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.72), 0 16rpx 32rpx rgba(63, 98, 88, 0.06);
}

.feature:active .circle {
  color: var(--brand-deep);
  border-color: rgba(63, 98, 88, 0.68);
  background: rgba(242, 247, 241, 0.9);
}

.feature-icon {
  width: 56rpx;
  height: 56rpx;
  background-color: transparent;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  mask-repeat: no-repeat;
  mask-position: center;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  -webkit-mask-size: contain;
}

