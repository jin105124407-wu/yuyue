.points-detail {
  background: var(--page-bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.points-header {
  margin: var(--space-md);
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: var(--radius-md);
  text-align: center;
  box-shadow: var(--shadow-gold);
}
.points-label {
  display: block;
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.7);
  margin-bottom: 16rpx;
}
.points-balance {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.tab-bar {
  display: flex;
  justify-content: center;
  padding: 0 var(--space-md);
  margin-bottom: var(--space-md);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: var(--text-lg);
  color: var(--text-muted);
  border-bottom: 4rpx solid transparent;
}
.tab.on {
  color: var(--primary);
  border-bottom-color: var(--primary);
  font-weight: 600;
}

.list {
  padding: 0 var(--space-md);
}
.record {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: var(--space-sm);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--divider);
}
.record-left {
  display: flex;
  align-items: center;
}
.record-type {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
  margin-right: 20rpx;
}
.record-type.income {
  background: var(--success-bg);
  color: var(--success);
}
.record-type.expense {
  background: var(--danger-bg);
  color: var(--danger);
}
.record-info {
  display: flex;
  flex-direction: column;
}
.record-title {
  font-size: var(--text-base);
  color: var(--text-primary);
  font-weight: 500;
}
.record-time {
  font-size: var(--text-xs);
  color: var(--text-muted);
  margin-top: 6rpx;
}
.record-amount {
  font-size: 40rpx;
  font-weight: 700;
}
.record-amount.plus { color: var(--success); }
.record-amount.minus { color: var(--text-primary); }

.empty {
  text-align: center;
  color: var(--text-muted);
  padding: 120rpx 0;
  font-size: var(--text-lg);
}