.voice-page {
  min-height: 100vh;
  padding: 28rpx 24rpx;
  background:
    linear-gradient(180deg, rgba(255, 252, 244, 0.58), transparent 420rpx),
    var(--page-bg);
  color: var(--text-primary);
}

.no-admin {
  padding: 200rpx 0;
  text-align: center;
  color: var(--danger);
  font-size: var(--text-lg);
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24rpx;
  padding: 8rpx 4rpx 28rpx;
}

.eyebrow,
.kicker,
.title {
  display: block;
}

.eyebrow {
  color: var(--text-muted);
  font-size: 22rpx;
}

.kicker {
  margin-top: 6rpx;
  color: var(--text-muted);
  font-size: var(--text-sm);
}

.title {
  margin-top: 8rpx;
  color: var(--text-primary);
  font-size: var(--text-3xl);
  font-weight: 700;
}

.status-panel {
  padding: 34rpx;
  border: 1rpx solid var(--divider);
  border-radius: 26rpx;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
}

.status-panel.speaking {
  border-color: var(--primary);
  background: var(--primary-bg);
}

.status-main,
.status-sub,
.section-title,
.notice-text,
.queue-service,
.queue-time,
.queue-count,
.notice-meta text,
.empty {
  display: block;
}

.status-main {
  font-size: var(--text-xl);
  font-weight: 700;
}

.status-sub {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: var(--text-sm);
  line-height: 1.6;
}

.controls {
  display: flex;
  gap: 18rpx;
  margin-top: var(--space-md);
}

.test-row {
  display: flex;
  gap: 18rpx;
  margin-top: 16rpx;
}

.control-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--card-bg);
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  border: 1rpx solid var(--divider);
  white-space: nowrap;
  box-sizing: border-box;
}

.control-btn.primary {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.control-btn.checking {
  opacity: 0.88;
}

.control-btn.disabled {
  color: var(--disabled);
  background: rgba(255, 255, 255, 0.62);
  border-color: rgba(200, 208, 204, 0.58);
}

.control-btn.test {
  color: var(--primary);
}

.control-btn.test.cancel {
  color: var(--danger);
}

.notice-card,
.queue,
.plugin-warning {
  margin-top: var(--space-lg);
  padding: 28rpx;
  border: 1rpx solid var(--divider);
  border-radius: 26rpx;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
}

.plugin-warning {
  border-color: rgba(184, 134, 11, 0.28);
  background: var(--warning-bg);
}

.warning-text {
  display: block;
  margin-top: 14rpx;
  color: var(--text-secondary);
  font-size: var(--text-sm);
  line-height: 1.7;
}

.section-title {
  color: var(--text-muted);
  font-size: var(--text-sm);
  font-weight: 600;
}

.notice-text {
  margin-top: 18rpx;
  color: var(--text-primary);
  font-size: var(--text-lg);
  line-height: 1.7;
}

.notice-meta {
  display: flex;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-top: 20rpx;
  color: var(--text-secondary);
  font-size: var(--text-sm);
}

.queue-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.queue-count {
  color: var(--primary);
  font-size: var(--text-sm);
}

.queue-item {
  display: flex;
  justify-content: space-between;
  gap: var(--space-sm);
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.queue-item:last-child {
  border-bottom: 0;
}

.queue-service {
  flex: 1;
  font-weight: 600;
  min-width: 0;
  line-height: 1.5;
}

.queue-time {
  color: var(--text-secondary);
  font-size: var(--text-sm);
}

.empty {
  padding: 48rpx 0 20rpx;
  color: var(--text-muted);
  text-align: center;
}
