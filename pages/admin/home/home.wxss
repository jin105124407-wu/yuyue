/* ================================================
   工作台首页 — 优雅管理面板
   ================================================ */
.admin-home {
  padding: 28rpx 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(255, 252, 244, 0.58), transparent 420rpx),
    var(--page-bg);
  min-height: 100vh;
}

.no-admin {
  margin-top: 72rpx;
  padding: 48rpx 32rpx;
  border: 1rpx solid rgba(200, 95, 85, 0.18);
  border-radius: 28rpx;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
  text-align: center;
  color: var(--text-primary);
}

.no-admin-title,
.no-admin-desc,
.openid-label,
.openid-value,
.admin-tip {
  display: block;
}

.no-admin-title {
  color: var(--danger);
  font-size: var(--text-xl);
  font-weight: 700;
}

.no-admin-desc {
  margin-top: 18rpx;
  color: var(--text-secondary);
  font-size: var(--text-sm);
  line-height: 1.7;
}

.openid-box {
  margin-top: 36rpx;
  padding: 28rpx;
  border: 1rpx solid var(--divider);
  border-radius: var(--radius-md);
  background: var(--card-bg);
  text-align: left;
}

.openid-label {
  color: var(--text-muted);
  font-size: var(--text-sm);
}

.openid-value {
  margin-top: 12rpx;
  color: var(--text-primary);
  font-size: 22rpx;
  line-height: 1.5;
  word-break: break-all;
}

.admin-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 28rpx;
}

.admin-btn {
  height: 88rpx;
  border-radius: var(--radius-md);
  background: var(--card-bg);
  color: var(--text-primary);
  font-size: var(--text-md);
}

.admin-btn.primary {
  background: var(--primary);
  color: #fff;
}

.admin-tip {
  margin-top: 22rpx;
  color: var(--text-secondary);
  font-size: var(--text-sm);
  line-height: 1.6;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24rpx;
  padding: 8rpx 4rpx 28rpx;
}
.eyebrow {
  display: block;
  color: var(--text-muted);
  font-size: 22rpx;
  letter-spacing: 0;
}
.title {
  display: block;
  margin-top: 6rpx;
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--text-primary);
}
.date {
  color: var(--text-muted);
  font-size: var(--text-sm);
  white-space: nowrap;
}
.header-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}
.exit-admin {
  min-width: 128rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(200, 95, 85, 0.26);
  border-radius: var(--radius-full);
  color: var(--danger);
  background: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 700;
}
.exit-admin:active {
  background: var(--danger-bg);
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}
.stat-card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx 12rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--divider);
  transition: var(--transition);
}
.stat-card:active { transform: scale(0.97); }
.stat-num {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 0;
  line-height: 1.1;
}
.stat-label {
  display: block;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 30rpx;
}
.action-item {
  min-height: 196rpx;
  background: var(--card-bg);
  border-radius: 26rpx;
  padding: 28rpx;
  text-align: left;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--divider);
  transition: var(--transition);
}
.action-item:active { transform: scale(0.97); background: var(--primary-bg); }
.action-icon {
  width: 64rpx;
  height: 64rpx;
  display: grid;
  place-items: center;
  margin-bottom: 22rpx;
  border-radius: 20rpx;
  background: var(--primary-bg);
  color: var(--primary-dark);
  position: relative;
}
.action-name {
  display: block;
  font-size: var(--text-md);
  font-weight: 600;
  color: var(--text-primary);
}
.action-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.45;
}

.action-icon::before,
.action-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.icon-orders::before {
  width: 30rpx;
  height: 36rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
}
.icon-orders::after {
  width: 18rpx;
  height: 4rpx;
  top: 27rpx;
  background: currentColor;
  box-shadow: 0 12rpx 0 currentColor;
}
.icon-voice::before {
  width: 18rpx;
  height: 24rpx;
  left: 18rpx;
  border-radius: 4rpx;
  background: currentColor;
}
.icon-voice::after {
  width: 24rpx;
  height: 34rpx;
  right: 12rpx;
  border-right: 4rpx solid currentColor;
  border-radius: 50%;
}
.icon-services::before {
  width: 34rpx;
  height: 34rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}
.icon-services::after {
  width: 26rpx;
  height: 4rpx;
  right: 10rpx;
  bottom: 15rpx;
  background: currentColor;
  transform: rotate(-35deg);
}
.icon-staff::before {
  width: 24rpx;
  height: 24rpx;
  top: 13rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}
.icon-staff::after {
  width: 38rpx;
  height: 20rpx;
  bottom: 10rpx;
  border: 4rpx solid currentColor;
  border-radius: 22rpx 22rpx 8rpx 8rpx;
}
