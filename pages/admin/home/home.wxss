/* ================================================
   工作台首页 — 优雅管理面板
   ================================================ */
.admin-home {
  padding: var(--space-md);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background: var(--page-bg);
  min-height: 100vh;
}

.no-admin {
  text-align: center;
  color: var(--danger);
  padding: 200rpx 0;
  font-size: var(--text-lg);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: var(--space-md) var(--space-xs);
}
.title {
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--text-primary);
}
.date {
  color: var(--text-muted);
  font-size: var(--text-sm);
}

/* 统计卡片 */
.stat-grid {
  display: flex;
  gap: var(--space-md);
}
.stat-card {
  flex: 1;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 36rpx 20rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--divider);
  transition: var(--transition);
}
.stat-card:active { transform: scale(0.97); }
.stat-num {
  display: block;
  font-size: var(--text-3xl);
  font-weight: 700;
  color: var(--primary);
  letter-spacing: -1rpx;
}
.stat-label {
  display: block;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: 8rpx;
}

/* 操作区 */
.action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  margin-top: var(--space-xl);
}
.action-item {
  flex: 1 1 calc(50% - var(--space-md));
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 40rpx 0;
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--divider);
  transition: var(--transition);
}
.action-item:active { transform: scale(0.97); background: var(--primary-bg); }
.action-icon {
  display: block;
  margin-bottom: 14rpx;
  font-size: 52rpx;
  line-height: 1;
}
.action-name {
  display: block;
  font-size: var(--text-md);
  font-weight: 600;
  color: var(--text-primary);
}