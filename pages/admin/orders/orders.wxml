<view class="admin-orders">
  <view class="orders-head">
    <view>
      <text class="page-kicker">Orders</text>
      <text class="page-title">订单管理</text>
    </view>
    <view class="refresh-btn" bindtap="fetchList">{{loading ? '刷新中' : '刷新'}}</view>
  </view>

  <view class="tabs">
    <view wx:for="{{tabs}}" wx:key="key"
          class="tab {{currentTab === item.key ? 'active' : ''}}"
          bindtap="onTabTap" data-key="{{item.key}}">{{item.label}}</view>
  </view>
  <view class="toolbar">
    <view class="tool-btn" bindtap="onMarkAll">全部已读</view>
  </view>

  <view class="list">
    <view wx:for="{{list}}" wx:key="_id"
          class="order-item {{!item.adminRead ? 'unread' : ''}}"
          bindtap="onOrderTap" data-item="{{item}}">
      <view class="order-head">
        <text class="order-service">{{item.serviceName}}</text>
        <view class="order-status status-{{item.status}}">
          {{item.status === 'pending' ? '待确认' :
            item.status === 'confirmed' ? '已确认' :
            item.status === 'done' ? '已完成' : '已取消'}}
        </view>
      </view>
      <view class="order-row">
        <text class="row-label">时间</text>
        <text class="row-value">{{item.date}} {{item.startTime}} - {{item.endTime}}</text>
      </view>
      <view class="order-row">
        <text class="row-label">美容师</text>
        <text class="row-value">{{item.staffName}}</text>
      </view>
      <view class="order-row">
        <text class="row-label">顾客</text>
        <text class="row-value">{{item.userSnapshot.nickname || '未命名'}} {{item.userSnapshot.phone}}</text>
      </view>
      <view class="order-remark" wx:if="{{item.remark}}">留言：{{item.remark}}</view>
    </view>
    <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无订单</view>
  </view>
</view>
