/* ================================================
   订单管理页 — 清晰高效
   ================================================ */
.admin-orders {
  min-height: 100vh;
  padding: 28rpx 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(255, 252, 244, 0.58), transparent 420rpx),
    var(--page-bg);
}

.orders-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  padding: 8rpx 4rpx 24rpx;
}

.page-kicker,
.page-title {
  display: block;
}

.page-kicker {
  color: var(--text-muted);
  font-size: 22rpx;
}

.page-title {
  margin-top: 6rpx;
  color: var(--text-primary);
  font-size: var(--text-2xl);
  font-weight: 700;
}

.refresh-btn {
  width: 132rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--primary);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.tabs {
  display: flex;
  position: sticky;
  top: 0;
  z-index: 5;
  overflow: hidden;
  border: 1rpx solid var(--divider);
  border-radius: 22rpx;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  color: var(--text-secondary);
  font-size: 24rpx;
  transition: var(--transition);
}
.tab.active {
  color: #fff;
  background: var(--primary);
  font-weight: 700;
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 0 0;
  gap: var(--space-sm);
}
.tool-btn {
  padding: 12rpx 26rpx;
  border: 1.5rpx solid var(--primary);
  color: var(--primary);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 500;
  background: var(--card-bg);
  transition: var(--transition);
}
.tool-btn:active { background: var(--primary-bg); }

.list { padding: 20rpx 0 0; }
.order-item {
  background: var(--card-bg);
  border-radius: 26rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 18rpx;
  border-left: 6rpx solid transparent;
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
}
.order-item.unread {
  border-left-color: var(--primary);
  background: var(--primary-bg);
}
.order-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 16rpx;
}
.order-service {
  flex: 1;
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.35;
}
.order-status {
  flex: 0 0 auto;
  min-width: 92rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-xs);
  padding: 0 16rpx;
  border-radius: var(--radius-full);
  font-weight: 700;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  box-sizing: border-box;
}
.status-pending { background: var(--warning-bg); color: var(--warning); }
.status-confirmed { background: var(--info-bg); color: var(--info); }
.status-done { background: var(--success-bg); color: var(--success); }
.status-canceled { background: var(--danger-bg); color: var(--danger); }
.order-row {
  display: flex;
  gap: 18rpx;
  font-size: var(--text-md);
  color: var(--text-secondary);
  margin: 10rpx 0;
  line-height: 1.5;
}
.row-label {
  flex: 0 0 88rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}
.row-value {
  flex: 1;
  min-width: 0;
  color: var(--text-secondary);
  word-break: break-all;
}
.order-remark {
  font-size: var(--text-sm);
  color: var(--text-muted);
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed var(--divider);
  line-height: 1.5;
}

.empty {
  border: 1rpx dashed var(--divider);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.58);
  text-align: center;
  color: var(--text-muted);
  padding: 120rpx 0;
  font-size: var(--text-lg);
}
