<view class="staff-admin">
  <view class="toolbar">
    <view>
      <text class="page-kicker">Staff</text>
      <text class="title">美容师管理</text>
    </view>
    <view class="add-btn" bindtap="onAdd">新增美容师</view>
  </view>

  <view class="list">
    <view wx:for="{{list}}" wx:key="_id" class="item">
      <view class="avatar-text">{{item.name ? item.name[0] : '?'}}</view>
      <view class="item-main">
        <text class="name">{{item.name}}<text class="disabled-tag" wx:if="{{item.enabled === false}}">已停用</text></text>
        <text class="meta">展示排序 {{item.sortOrder}}</text>
      </view>
      <view class="item-actions">
        <view class="action" bindtap="onEdit" data-item="{{item}}">编辑</view>
        <view class="action danger" bindtap="onRemove" data-id="{{item._id}}">停用</view>
      </view>
    </view>
    <view wx:if="{{list.length === 0}}" class="empty-state">
      <text class="empty-title">暂无美容师</text>
      <text class="empty-desc">新增美容师后，用户预约时可选择服务人员。</text>
    </view>
  </view>

  <view wx:if="{{editing}}" class="modal-mask" bindtap="onCancel">
    <view class="modal" catchtap>
      <text class="modal-title">{{editing._id ? '编辑美容师' : '新增美容师'}}</text>
      <view class="avatar-pick" bindtap="onChooseAvatar">
        <view class="big-avatar-text">{{editing.name ? editing.name[0] : '?'}}</view>
        <text>点击更换头像</text>
      </view>
      <view class="field"><text>姓名</text><input placeholder="请输入姓名" value="{{editing.name}}" data-key="name" bindinput="onInput"/></view>
      <view class="field"><text>排序</text><input type="number" placeholder="数字越小越靠前" value="{{editing.sortOrder}}" data-key="sortOrder" bindinput="onInput"/></view>
      <view class="field"><text>启用</text><switch checked="{{editing.enabled !== false}}" bindchange="onToggleEnabled"/></view>
      <view class="modal-actions">
        <view class="btn" bindtap="onCancel">取消</view>
        <view class="btn primary" bindtap="onSave">保存</view>
      </view>
    </view>
  </view>
</view>
