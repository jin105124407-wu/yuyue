/* ================================================
   美容师管理页
   ================================================ */
.staff-admin {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background: var(--page-bg);
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md);
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--divider);
}
.title {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--text-primary);
}
.add-btn {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  padding: 14rpx 32rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 500;
  box-shadow: var(--shadow-gold);
  border: none;
}
.add-btn::after { border: none; }

.list { padding: var(--space-md); }
.item {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin-bottom: var(--space-md);
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--divider);
}
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--primary-light);
  border: 3rpx solid var(--divider);
  flex-shrink: 0;
}
.avatar-text {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
}
.item-main { flex: 1; margin-left: var(--space-md); }
.name {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
}
.disabled-tag {
  font-size: var(--text-xs);
  background: var(--page-bg);
  color: var(--text-muted);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  margin-left: var(--space-sm);
  border: 1rpx solid var(--divider);
}
.meta {
  display: block;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: 8rpx;
}
.item-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-left: var(--space-md);
}
.action {
  font-size: var(--text-xs);
  padding: 10rpx 22rpx;
  border: 1.5rpx solid var(--primary);
  color: var(--primary);
  border-radius: var(--radius-full);
  background: var(--card-bg);
  transition: var(--transition);
}
.action.danger {
  border-color: var(--danger);
  color: var(--danger);
}
.action:active { opacity: 0.7; }

/* 弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(44,36,32,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(4rpx);
}
.modal {
  width: 640rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 40rpx 36rpx;
  box-shadow: var(--shadow-lg);
}
.modal-title {
  font-size: var(--text-xl);
  font-weight: 700;
  display: block;
  text-align: center;
  color: var(--primary);
  margin-bottom: var(--space-lg);
}

.avatar-pick {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 28rpx 0;
}
.big-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: var(--primary-light);
  border: 4rpx solid var(--primary-light);
  margin-bottom: 14rpx;
}
.big-avatar-text {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 14rpx;
}
.avatar-pick text {
  font-size: var(--text-sm);
  color: var(--text-muted);
}

.field {
  display: flex;
  align-items: center;
  margin-top: var(--space-md);
  border-bottom: 1rpx solid var(--divider);
  padding: 16rpx 0;
}
.field > text {
  width: 160rpx;
  color: var(--text-secondary);
  font-size: var(--text-md);
  flex-shrink: 0;
}
.field input {
  flex: 1;
  font-size: var(--text-md);
  color: var(--text-primary);
  background: transparent;
}

.modal-actions {
  display: flex;
  gap: var(--space-md);
  margin-top: 36rpx;
}
.btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border: 1.5rpx solid var(--divider);
  border-radius: var(--radius-full);
  font-size: var(--text-md);
  color: var(--text-secondary);
  background: var(--card-bg);
  transition: var(--transition);
}
.btn.primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  border-color: var(--primary);
  box-shadow: var(--shadow-gold);
}
.btn:active { transform: scale(0.97); }