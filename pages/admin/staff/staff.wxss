/* ================================================
   美容师管理页
   ================================================ */
.staff-admin {
  min-height: 100vh;
  padding: 28rpx 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(255, 252, 244, 0.58), transparent 420rpx),
    var(--page-bg);
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24rpx;
  padding: 8rpx 4rpx 24rpx;
}
.page-kicker {
  display: block;
  color: var(--text-muted);
  font-size: 22rpx;
}
.title {
  display: block;
  margin-top: 6rpx;
  font-size: var(--text-2xl);
  font-weight: 700;
  color: var(--text-primary);
}
.add-btn {
  width: 196rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 700;
}
.add-btn::after { border: none; }

.list { padding: 0; }
.empty-state {
  margin-top: 8rpx;
  padding: 96rpx 40rpx;
  border: 1rpx dashed var(--divider);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.58);
  text-align: center;
}
.empty-title,
.empty-desc {
  display: block;
}
.empty-title {
  color: var(--text-primary);
  font-size: var(--text-lg);
  font-weight: 700;
}
.empty-desc {
  margin-top: 12rpx;
  color: var(--text-muted);
  font-size: var(--text-sm);
  line-height: 1.6;
}
.item {
  background: var(--card-bg);
  border-radius: 26rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--divider);
}
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--primary-light);
  border: 3rpx solid var(--divider);
  flex-shrink: 0;
}
.avatar-text {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: var(--primary-bg);
  border: 1rpx solid rgba(95, 127, 115, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: var(--primary-dark);
  font-weight: 700;
  flex-shrink: 0;
}
.item-main {
  flex: 1;
  min-width: 0;
}
.name {
  display: block;
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.35;
}
.disabled-tag {
  font-size: var(--text-xs);
  background: var(--page-bg);
  color: var(--text-muted);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  margin-left: var(--space-sm);
  border: 1rpx solid var(--divider);
}
.meta {
  display: block;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: 10rpx;
}
.item-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  flex: 0 0 108rpx;
}
.action {
  min-height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 1.5rpx solid var(--primary);
  color: var(--primary);
  border-radius: var(--radius-full);
  background: var(--card-bg);
  transition: var(--transition);
}
.action.danger {
  border-color: var(--danger);
  color: var(--danger);
}
.action:active { opacity: 0.7; }

/* 弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(44,36,32,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(4rpx);
}
.modal {
  width: 680rpx;
  max-width: calc(100vw - 48rpx);
  background: var(--card-bg);
  border-radius: 28rpx;
  padding: 38rpx 34rpx;
  box-shadow: var(--shadow-lg);
}
.modal-title {
  font-size: var(--text-xl);
  font-weight: 700;
  display: block;
  text-align: center;
  color: var(--primary);
  margin-bottom: var(--space-lg);
}

.avatar-pick {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 28rpx 0;
}
.big-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: var(--primary-light);
  border: 4rpx solid var(--primary-light);
  margin-bottom: 14rpx;
}
.big-avatar-text {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: var(--primary-bg);
  border: 1rpx solid rgba(95, 127, 115, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: var(--primary-dark);
  font-weight: 700;
  margin-bottom: 14rpx;
}
.avatar-pick text {
  font-size: var(--text-sm);
  color: var(--text-muted);
}

.field {
  display: flex;
  align-items: center;
  margin-top: var(--space-md);
  border: 1rpx solid var(--divider);
  border-radius: 18rpx;
  padding: 0 22rpx;
  min-height: 88rpx;
  background: #fff;
}
.field > text {
  width: 132rpx;
  color: var(--text-secondary);
  font-size: var(--text-md);
  flex-shrink: 0;
}
.field input {
  flex: 1;
  font-size: var(--text-md);
  color: var(--text-primary);
  background: transparent;
}

.modal-actions {
  display: flex;
  gap: var(--space-md);
  margin-top: 36rpx;
}
.btn {
  flex: 1;
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  border: 1.5rpx solid var(--divider);
  border-radius: var(--radius-full);
  font-size: var(--text-md);
  color: var(--text-secondary);
  background: var(--card-bg);
  transition: var(--transition);
}
.btn.primary {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}
.btn:active { transform: scale(0.97); }
