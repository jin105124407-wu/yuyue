.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(152rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  align-items: end;
  padding: 20rpx 0 env(safe-area-inset-bottom);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94), #fff 42%),
    rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(231, 236, 232, 0.86);
  box-shadow: 0 -14rpx 30rpx rgba(63, 98, 88, 0.06);
  z-index: 999;
}

.tab-bar::before {
  content: "";
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 40rpx;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(196, 216, 209, 0.58) 0,
    rgba(196, 216, 209, 0.72) 5%,
    rgba(196, 216, 209, 0.72) 40.5%,
    transparent 40.5%,
    transparent 59.5%,
    rgba(196, 216, 209, 0.72) 59.5%,
    rgba(196, 216, 209, 0.72) 95%,
    rgba(196, 216, 209, 0.58) 100%
  );
}

.tab-item {
  position: relative;
  min-width: 0;
  height: 116rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #7f8b86;
  font-size: 22rpx;
  line-height: 1;
}

.tab-item.selected {
  color: var(--brand-deep);
  font-weight: 700;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  display: grid;
  place-items: center;
  color: currentColor;
  line-height: 1;
}

.line-icon {
  width: 44rpx;
  height: 44rpx;
  background-position: center;
  background-repeat: no-repeat;
  background-size: 44rpx 44rpx;
}

.customer-mode .tab-icon-0 .line-icon {
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg' fill='none' stroke='%237f8b86' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='M3 10.8 12 4l9 6.8'/%3E%3Cpath d='M5.5 10.4V20h13v-9.6'/%3E%3Cpath d='M9.5 20v-6h5v6'/%3E%3C/svg%3E");
}

